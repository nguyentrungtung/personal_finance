# Database
DB_PATH=./data/courtify.db

# JWT
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=15m

# File uploads
UPLOAD_PATH=./uploads

# Frontend API base URL (used by Vite)
VITE_API_URL=http://localhost:5000

# Initial admin user (created on first startup if no user exists)
INIT_EMAIL=admin@example.com
INIT_PASSWORD=change-me-secure-password
